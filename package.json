{
  "name": "@indiekit/pg-top",
  "version": "0.1.0",
  "description": "Real-time PostgreSQL activity monitor — like top for Postgres",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pg-top": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "keywords": ["postgresql", "monitor", "pg_activity", "top", "mcp"],
  "license": "MIT"
}
